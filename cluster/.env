# =============================================================================
# CLIF Cluster Mode — Environment Variables
# =============================================================================
# This file contains ONLY the cluster-specific overrides.
# It is loaded AFTER the main .env file via:
#   docker compose -f docker-compose.pcX.yml --env-file .env --env-file cluster/.env up -d
# =============================================================================

# ── DATA_IP: PC1's LAN IP address ──────────────────────────────────────────
# REQUIRED — set this to PC1's actual LAN IP (e.g. 192.168.1.100)
# Find it with: ipconfig | findstr IPv4     (on PC1)
DATA_IP=10.180.247.221

# ── Redpanda tuning (right-sized for 6C/12T, 16 GB PCs) ───────────────────
# Each broker: 1 seastar thread (--smp 1), 1.5G managed memory, 2G Docker cap
# Total: 3 brokers × 1.5G working = 4.5G managed by Redpanda (actual ~500M each)
REDPANDA_MEMORY=1500M
REDPANDA_MEM_LIMIT=2G
REDPANDA_SMP=1
